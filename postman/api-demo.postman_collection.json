          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Basket response contains id and name\", function () {",
                  "  pm.expect(json).to.have.property(\"id\");",
                  "  pm.expect(json).to.have.property(\"name\");",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"basketId\", json.id);",
                  "if (json.items && json.items.length > 0) {",
                  "  pm.collectionVariables.set(\"itemId\", json.items[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Basket - With Items (201)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/baskets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Basket With Items\",\n  \"items\": [\n    {\n      \"productName\": \"Coffee\",\n      \"itemNo\": 1,\n      \"quantity\": 2,\n      \"unitPrice\": 4.5\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Basket contains at least one item\", function () {",
                  "  pm.expect(json.items).to.be.an(\"array\");",
                  "  pm.expect(json.items.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"basketId\", json.id);",
                  "if (json.items && json.items.length > 0) {",
                  "  pm.collectionVariables.set(\"itemId\", json.items[0].id);",
                  "}"
                ]
              }
