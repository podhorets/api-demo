        {
          "name": "Request Password Reset - Success (200)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/password-reset/request",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Extract token from response",
                  "try {",
                  "  const json = pm.response.json();",
                  "  const token = json.token || '';",
                  "  if (token) {",
                  "    pm.collectionVariables.set(\"passwordResetToken\", token);",
                  "    console.log('Password reset token set:', token);",
                  "  } else {",
                  "    console.warn('No token found in response');",
                  "  }",
                  "} catch (e) {",
                  "  console.error('Failed to parse response JSON:', e);",
                  "}"
                ]
              }
            }
          ]
        },
