      "item": [
        {
          "name": "Signup - Success (201)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/auth/signup",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Demo\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `postman.demo+${Date.now()}@example.com`;",
                  "pm.collectionVariables.set('authEmail', email);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Response contains userId and tokens\", function () {",
                  "  pm.expect(json).to.have.property(\"userId\");",
                  "  pm.expect(json).to.have.property(\"accessToken\");",
                  "  pm.expect(json).to.have.property(\"refreshToken\");",
                  "});",
                  "",
                  "if (json.accessToken) pm.collectionVariables.set(\"accessToken\", json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set(\"refreshToken\", json.refreshToken);"
                ]
              }
            }
          ]
        },
