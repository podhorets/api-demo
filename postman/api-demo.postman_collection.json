          "name": "Create Basket - Empty Basket (201)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/baskets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Basket\"\n}",
              "options": {
                "raw": {
