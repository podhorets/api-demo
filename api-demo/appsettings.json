{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer": "ApiDemo",
    "Audience": "ApiDemo",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "PasswordResetTokenMinutes": 60
  }
}
